---
import SEO from "../components/SEO.astro";
import type { Lang } from "../i18n/ui";
import "../styles/gadmin-bio.css";

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  image?: string;
  canonicalURL?: string | URL;
  lang?: Lang;
  schema?: Record<string, unknown>;
}

const {
  title,
  description,
  keywords,
  image,
  canonicalURL,
  lang = "es",
  schema,
} = Astro.props;

const siteUrl = Astro.site
  ? Astro.site.toString().replace(/\/$/, "")
  : "https://gadmin.app";

// Gadmin Ecosystem Organization Schema
const gadminSchema = schema ?? {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      name: "Gadmin",
      url: siteUrl,
      logo: {
        "@type": "ImageObject",
        url: `${siteUrl}/favicon.png`,
      },
      description: description,
      sameAs: [
        "https://www.instagram.com/gadmin.app/",
        "https://www.tiktok.com/@gadmin.app",
        "https://www.linkedin.com/company/gadminapp",
      ],
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      url: siteUrl,
      name: "Gadmin",
      inLanguage: lang === "es" ? "es" : "en",
      publisher: { "@id": `${siteUrl}/#organization` },
    },
    {
      "@type": "ItemList",
      "@id": `${siteUrl}/#apps`,
      name: lang === "es" ? "Apps de Gadmin" : "Gadmin Apps",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          item: {
            "@type": "SoftwareApplication",
            name: "Conty",
            url: "https://gadminconty.com",
            applicationCategory: "BusinessApplication, FinanceApplication",
            operatingSystem: "Android",
            offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
          },
        },
        {
          "@type": "ListItem",
          position: 2,
          item: {
            "@type": "SoftwareApplication",
            name: "Gadmin Shop",
            url: siteUrl,
            applicationCategory: "BusinessApplication",
            operatingSystem: "Android",
          },
        },
      ],
    },
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <SEO
      title={title}
      description={description}
      keywords={keywords}
      image={image}
      canonicalURL={canonicalURL}
      lang={lang}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(gadminSchema)}
    />
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    scroll-behavior: smooth;
  }
</style>
